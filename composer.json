{
    "name": "synolia/sylius-gdpr-plugin",
    "type": "sylius-plugin",
    "description": "Synolia sylius GDPR plugin.",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "gdpr",
        "rgpd",
        "synolia"
    ],
    "license": "EUPL-1.2",
    "require": {
        "php": "^8.0",
        "php-http/message-factory": "^1.1",
        "phpdocumentor/reflection-docblock": "^5.3",
        "sylius/sylius": "^2.0",
        "symfony/property-info": "^5.4|^6.0"
    },
    "require-dev": {
        "j13k/yaml-lint": "^1.1",
        "php-parallel-lint/php-parallel-lint": "^1.3.2",
        "phpmd/phpmd": "^2.13",
        "phpro/grumphp": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-doctrine": "^1.5",
        "phpstan/phpstan-webmozart-assert": "^1.2",
        "phpunit/phpunit": ">=9.5",
        "povils/phpmnd": "^3.0",
        "rector/rector": "^1.0",
        "seld/jsonlint": "^1.9",
        "sylius-labs/coding-standard": "4.3.0",
        "symfony/browser-kit": "^6.4",
        "symfony/debug-bundle": "^6.4",
        "symfony/dotenv": "^6.4",
        "symfony/intl": "^6.4",
        "symfony/web-profiler-bundle": "^6.4",
        "thecodingmachine/phpstan-strict-rules": "1.0.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "symfony/thanks": true,
            "phpro/grumphp": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "Synolia\\SyliusGDPRPlugin\\": "src/",
            "Tests\\Synolia\\SyliusGDPRPlugin\\": "tests/"
        }
    },
    "scripts": {
        "fix-ecs": "ecs check -c ruleset/ecs.php --fix --ansi --clear-cache .",
        "post-install-cmd": [
            "php bin/create_node_symlink.php"
        ],
        "post-update-cmd": [
            "php bin/create_node_symlink.php"
        ],
        "post-create-project-cmd": [
            "php bin/create_node_symlink.php"
        ]
    }
}
